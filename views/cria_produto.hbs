<div class="card p-4">
  <h4>Cadastro de Produto</h4>
  {{#if erros}}
    <div class="alert alert-danger">
      <ul class="mb-0">
        {{#each erros}}
          <li>{{this}}</li>
        {{/each}}
      </ul>
    </div>
  {{/if}}
  <form action="/produto/cria" method="POST">
    <div class="row mb-3">
      <div class="col">
        <label class="form-label">Nome</label>
        <input type="text" name="nome" class="form-control" value="{{valores.nome}}">
      </div>
      <div class="col">
        <label class="form-label">Preço (R$)</label>
        <input type="number" step="0.01" name="preco" class="form-control" value="{{valores.preco}}">
      </div>
    </div>
    <div class="mb-3">
      <label class="form-label">Descrição</label>
      <textarea name="descricao" class="form-control" rows="3" placeholder="Descrição do produto">{{valores.descricao}}</textarea>
    </div>
    <div class="row mb-3">
      <div class="col">
        <label class="form-label">Quantidade em Estoque</label>
        <input type="number" name="quantidade" class="form-control" value="{{valores.quantidade}}">
      </div>
      <div class="col">
        <label class="form-label">Status</label>
        <select name="status" class="form-select">
          <option value="">Selecione...</option>
          <option value="ativo" {{#if (eq valores.status "ativo")}}selected{{/if}}>Ativo</option>
          <option value="inativo" {{#if (eq valores.status "inativo")}}selected{{/if}}>Inativo</option>
        </select>
      </div>
      <div class="col">
        <label class="form-label">Categoria</label>
        <select name="categoria_id" class="form-select">
          <option value="">Selecione...</option>
          {{#each categorias}}
            <option value="{{id}}">{{nome}}</option>
          {{/each}}
        </select>
      </div>
    </div>
    <div class="row mb-3">
      <div class="col-md-4">
        <label class="form-label">Usuário Responsável</label>
        <select name="usuario_id" class="form-select">
          <option value="">Selecione...</option>
          {{#each usuarios}}
            <option value="{{id}}">{{nome}}</option>
          {{/each}}
        </select>
      </div>
    </div>
    <button type="submit" class="btn btn-primary">Cadastrar</button>
    <a href="/" class="btn btn-secondary">Cancelar</a>
  </form>
</div>
